{
    "name": "Solar Rosette - Complete System (Appointments + Users with Phone)",
    "nodes": [
        {
            "parameters": {
                "httpMethod": "POST",
                "path": "appointments",
                "responseMode": "responseNode",
                "options": {}
            },
            "name": "Webhook Create Appointment",
            "type": "n8n-nodes-base.webhook",
            "typeVersion": 1,
            "position": [
                200,
                300
            ],
            "webhookId": "create-appt-webhook",
            "id": "webhook-create-appt"
        },
        {
            "parameters": {
                "functionCode": "const staticData = getWorkflowStaticData('global');\nif (!staticData.appointments) { staticData.appointments = []; }\nconst body = items[0].json.body;\n\n// CONFLICT DETECTION\nconst conflict = staticData.appointments.find(a => \n  a.dateStr == body.dateStr && \n  a.time == body.time &&\n  a.status != 'CANCELADA'\n);\nif (conflict) {\n  return [{ json: { success: false, message: 'Lo sentimos, esta hora ya está ocupada por otro paciente.' } }];\n}\n\nconst newAppt = {\n  id: Date.now(),\n  patientName: body.patientName,\n  patientCedula: body.patientCedula,\n  dateStr: body.dateStr,\n  time: body.time,\n  type: body.type || 'Cita',\n  status: 'PENDIENTE',\n  color: 'bg-orange'\n};\nstaticData.appointments.push(newAppt);\nreturn [{ json: { success: true, appointment: newAppt } }];"
            },
            "name": "Create Appointment Logic",
            "type": "n8n-nodes-base.function",
            "typeVersion": 1,
            "position": [
                450,
                300
            ],
            "id": "create-appt-logic"
        },
        {
            "parameters": {
                "options": {}
            },
            "name": "Respond Create Appointment",
            "type": "n8n-nodes-base.respondToWebhook",
            "typeVersion": 1,
            "position": [
                700,
                300
            ],
            "id": "respond-create-appt"
        },
        {
            "parameters": {
                "httpMethod": "GET",
                "path": "appointments",
                "responseMode": "responseNode",
                "options": {}
            },
            "name": "Webhook Get Appointments",
            "type": "n8n-nodes-base.webhook",
            "typeVersion": 1,
            "position": [
                200,
                500
            ],
            "webhookId": "get-appts-webhook",
            "id": "webhook-get-appts"
        },
        {
            "parameters": {
                "functionCode": "const staticData = getWorkflowStaticData('global');\nconst allAppts = staticData.appointments || [];\nconst query = items[0].json.query;\nconst userCedula = query.cedula;\nconst userRole = query.role;\n\nlet myAppts = [];\n// DATA ISOLATION LOGIC\nif (userRole === 'professional' || userRole === 'admin') {\n    // Admin/Pro see EVERYTHING\n    myAppts = allAppts;\n} else {\n    // Patients see ONLY their own based on CEDULA match\n    if (!userCedula) {\n        myAppts = [];\n    } else {\n        myAppts = allAppts.filter(a => a.patientCedula == userCedula);\n    }\n}\nreturn [{ json: { success: true, appointments: myAppts } }];"
            },
            "name": "Get Appointments Logic",
            "type": "n8n-nodes-base.function",
            "typeVersion": 1,
            "position": [
                450,
                500
            ],
            "id": "get-appts-logic"
        },
        {
            "parameters": {
                "options": {}
            },
            "name": "Respond Get Appointments",
            "type": "n8n-nodes-base.respondToWebhook",
            "typeVersion": 1,
            "position": [
                700,
                500
            ],
            "id": "respond-get-appts"
        },
        {
            "parameters": {
                "httpMethod": "PUT",
                "path": "appointments",
                "responseMode": "responseNode",
                "options": {}
            },
            "name": "Webhook Update Appointment",
            "type": "n8n-nodes-base.webhook",
            "typeVersion": 1,
            "position": [
                200,
                700
            ],
            "webhookId": "update-appt-webhook",
            "id": "webhook-update-appt"
        },
        {
            "parameters": {
                "functionCode": "const staticData = getWorkflowStaticData('global');\nif (!staticData.appointments) { staticData.appointments = []; }\nconst body = items[0].json.body;\nconst apptId = body.id;\nconst newStatus = body.status;\n\nconst appt = staticData.appointments.find(a => a.id == apptId);\nif (!appt) {\n  return [{ json: { success: false, message: 'Cita no encontrada' } }];\n}\n\nappt.status = newStatus;\nif (newStatus === 'APROBADA') appt.color = 'bg-green';\nelse if (newStatus === 'CANCELADA') appt.color = 'bg-red';\nelse appt.color = 'bg-orange';\n\nreturn [{ json: { success: true, appointment: appt } }];"
            },
            "name": "Update Appointment Logic",
            "type": "n8n-nodes-base.function",
            "typeVersion": 1,
            "position": [
                450,
                700
            ],
            "id": "update-appt-logic"
        },
        {
            "parameters": {
                "options": {}
            },
            "name": "Respond Update Appointment",
            "type": "n8n-nodes-base.respondToWebhook",
            "typeVersion": 1,
            "position": [
                700,
                700
            ],
            "id": "respond-update-appt"
        },
        {
            "parameters": {
                "httpMethod": "POST",
                "path": "register",
                "responseMode": "responseNode",
                "options": {}
            },
            "name": "Webhook Register User",
            "type": "n8n-nodes-base.webhook",
            "typeVersion": 1,
            "position": [
                200,
                1000
            ],
            "webhookId": "register-webhook",
            "id": "webhook-register"
        },
        {
            "parameters": {
                "functionCode": "const staticData = getWorkflowStaticData('global');\nif (!staticData.users) { staticData.users = []; }\n\nconst body = items[0].json.body;\n\n// Check if user already exists\nconst existingUser = staticData.users.find(u => u.cedula === body.cedula);\nif (existingUser) {\n  return [{ json: { success: false, message: 'Usuario ya registrado con esta cédula' } }];\n}\n\n// Create new user WITH PHONE FIELD\nconst newUser = {\n  id: Date.now(),\n  name: body.name,\n  email: body.email,\n  cedula: body.cedula,\n  phone: body.phone || '',\n  role: body.role,\n  type: body.type || '',\n  notes: [],\n  createdAt: new Date().toISOString()\n};\n\nstaticData.users.push(newUser);\n\nreturn [{ json: { success: true, user: newUser, message: 'Usuario registrado exitosamente' } }];"
            },
            "name": "Register User Logic",
            "type": "n8n-nodes-base.function",
            "typeVersion": 1,
            "position": [
                450,
                1000
            ],
            "id": "register-logic"
        },
        {
            "parameters": {
                "options": {}
            },
            "name": "Respond Register User",
            "type": "n8n-nodes-base.respondToWebhook",
            "typeVersion": 1,
            "position": [
                700,
                1000
            ],
            "id": "respond-register"
        },
        {
            "parameters": {
                "httpMethod": "GET",
                "path": "users",
                "responseMode": "responseNode",
                "options": {}
            },
            "name": "Webhook Get Users",
            "type": "n8n-nodes-base.webhook",
            "typeVersion": 1,
            "position": [
                200,
                1200
            ],
            "webhookId": "get-users-webhook",
            "id": "webhook-get-users"
        },
        {
            "parameters": {
                "functionCode": "const staticData = getWorkflowStaticData('global');\nif (!staticData.users) { staticData.users = []; }\n\nconst query = items[0].json.query || {};\n\n// Filter by cedula if provided\nif (query.cedula) {\n  const user = staticData.users.find(u => u.cedula === query.cedula);\n  if (user) {\n    return [{ json: { success: true, user: user } }];\n  } else {\n    return [{ json: { success: false, message: 'Usuario no encontrado' } }];\n  }\n}\n\n// Filter by role if provided\nif (query.role) {\n  const filteredUsers = staticData.users.filter(u => u.role === query.role);\n  return [{ json: { success: true, users: filteredUsers, count: filteredUsers.length } }];\n}\n\n// Return all users\nreturn [{ json: { success: true, users: staticData.users, count: staticData.users.length } }];"
            },
            "name": "Get Users Logic",
            "type": "n8n-nodes-base.function",
            "typeVersion": 1,
            "position": [
                450,
                1200
            ],
            "id": "get-users-logic"
        },
        {
            "parameters": {
                "options": {}
            },
            "name": "Respond Get Users",
            "type": "n8n-nodes-base.respondToWebhook",
            "typeVersion": 1,
            "position": [
                700,
                1200
            ],
            "id": "respond-get-users"
        },
        {
            "parameters": {
                "httpMethod": "PUT",
                "path": "users",
                "responseMode": "responseNode",
                "options": {}
            },
            "name": "Webhook Update User",
            "type": "n8n-nodes-base.webhook",
            "typeVersion": 1,
            "position": [
                200,
                1400
            ],
            "webhookId": "update-user-webhook",
            "id": "webhook-update-user"
        },
        {
            "parameters": {
                "functionCode": "const staticData = getWorkflowStaticData('global');\nif (!staticData.users) { staticData.users = []; }\n\nconst body = items[0].json.body;\n\nif (!body.cedula) {\n  return [{ json: { success: false, message: 'Cédula requerida' } }];\n}\n\nconst userIndex = staticData.users.findIndex(u => u.cedula === body.cedula);\n\nif (userIndex === -1) {\n  return [{ json: { success: false, message: 'Usuario no encontrado' } }];\n}\n\n// Update user fields (including phone)\nif (body.name) staticData.users[userIndex].name = body.name;\nif (body.email) staticData.users[userIndex].email = body.email;\nif (body.phone !== undefined) staticData.users[userIndex].phone = body.phone;\nif (body.notes) staticData.users[userIndex].notes = body.notes;\n\nstaticData.users[userIndex].updatedAt = new Date().toISOString();\n\nreturn [{ json: { success: true, user: staticData.users[userIndex], message: 'Usuario actualizado' } }];"
            },
            "name": "Update User Logic",
            "type": "n8n-nodes-base.function",
            "typeVersion": 1,
            "position": [
                450,
                1400
            ],
            "id": "update-user-logic"
        },
        {
            "parameters": {
                "options": {}
            },
            "name": "Respond Update User",
            "type": "n8n-nodes-base.respondToWebhook",
            "typeVersion": 1,
            "position": [
                700,
                1400
            ],
            "id": "respond-update-user"
        }
    ],
