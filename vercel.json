{
  "version": 2,
  "cleanUrls": true,
  "rewrites": [
    { "source": "/", "destination": "/public/index.html" },
    { "source": "/login", "destination": "/public/login.html" },
    { "source": "/register", "destination": "/public/register.html" },
    { "source": "/agenda", "destination": "/public/agenda.html" },
    { "source": "/admin", "destination": "/public/dashboards/admin_dashboard_local.html" },
    { "source": "/professional", "destination": "/public/dashboards/professional_dashboard.html" },
    { "source": "/(.*)", "destination": "/public/$1" }
  ]
}
